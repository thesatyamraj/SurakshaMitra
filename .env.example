# ─────────────────────────────────────────────────────────────
# SurakshaMitra Unified — environment variables
# Copy this file to `.env` (root) for the BACKEND. Nothing here is
# committed. Everything optional degrades gracefully if left blank.
# ─────────────────────────────────────────────────────────────

# ── Core (required) ──────────────────────────────────────────
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/surakshamitra?retryWrites=true&w=majority
FRONTEND_URL=http://localhost:3000        # in Render set this to your Vercel URL, e.g. https://your-app.vercel.app

# Two SEPARATE JWT secrets (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Seed admin (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@surakshamitra.app
SEED_ADMIN_PASSWORD=Admin@12345

# ── AI (optional — falls back to keyword answers) ────────────
GEMINI_API_KEY=                           # aistudio.google.com/apikey (used by /api/chat)

# ── Email (optional — stubs if unset) ────────────────────────
# Preferred for Brevo Transactional Email:
BREVO_API_KEY=
BREVO_FROM=SurakshaMitra <verified-sender@example.com>

# SMTP fallback:
SMTP_HOST=                                # e.g. smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SurakshaMitra <verified-sender@example.com>

# ── SMS (optional — native sms: deeplink is free & always on) ─
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Web Push (optional) — generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Media storage (optional — incident photos) ───────────────
# If unset, photos save to backend/uploads/ on disk (fine for local/dev).
CLOUDINARY_URL=
