# Frontend (Vite) — copy to frontend/.env . Vars must start with VITE_.
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Map default centre (Bengaluru). Change per city.
VITE_MAP_CENTER_LAT=12.9716
VITE_MAP_CENTER_LNG=77.5946

# Optional: enables Safe-Route planning. Free key at openrouteservice.org/dev
VITE_ORS_API_KEY=
